#!/usr/bin/env php
<?php
/**
 * HyperSpeed Pro - Command Line Interface
 * 
 * Manage HyperSpeed Pro from the command line
 * 
 * @package HyperSpeed Pro
 * @version 1.0.0
 */

// Ensure running as CLI
if (php_sapi_name() !== 'cli') {
    die("This script must be run from command line.\n");
}

// Check if running as root
if (posix_geteuid() !== 0) {
    die("This script must be run as root.\n");
}

// Load configuration
$configFile = '/etc/hyperspeed_pro/hyperspeed.conf';
if (!file_exists($configFile)) {
    die("HyperSpeed Pro is not installed. Configuration file not found.\n");
}

$config = json_decode(file_get_contents($configFile), true);

// Parse command line arguments
$command = $argv[1] ?? 'help';
$options = array_slice($argv, 2);

// Command router
switch ($command) {
    case 'status':
        showStatus();
        break;
    
    case 'flush':
        flushCache($options);
        break;
    
    case 'stats':
        showStatistics();
        break;
    
    case 'enable':
        enableFeature($options);
        break;
    
    case 'disable':
        disableFeature($options);
        break;
    
    case 'blacklist':
        manageBlacklist($options);
        break;
    
    case 'whitelist':
        manageWhitelist($options);
        break;
    
    case 'optimize':
        runOptimization();
        break;
    
    case 'test':
        runTests();
        break;
    
    case 'help':
    default:
        showHelp();
        break;
}

/**
 * Show HyperSpeed Pro status
 */
function showStatus() {
    global $config;
    
    echo "HyperSpeed Pro Status\n";
    echo str_repeat("=", 50) . "\n\n";
    
    echo "Version: 1.0.0\n";
    echo "Status: " . ($config['enabled'] ? "✓ Active" : "✗ Inactive") . "\n\n";
    
    // Check services
    echo "Services:\n";
    
    // Redis
    $redisStatus = checkService('redis-server');
    echo "  Redis: " . ($redisStatus ? "✓ Running" : "✗ Stopped") . "\n";
    
    // Memcached
    $memcachedStatus = checkService('memcached');
    echo "  Memcached: " . ($memcachedStatus ? "✓ Running" : "✗ Stopped") . "\n";
    
    // HyperSpeed Engine
    $engineStatus = checkService('hyperspeed-engine');
    echo "  Engine: " . ($engineStatus ? "✓ Running" : "✗ Stopped") . "\n";
    
    echo "\n";
    
    // Feature status
    echo "Features:\n";
    echo "  Page Caching: " . ($config['cache']['page_cache'] ? "✓ Enabled" : "✗ Disabled") . "\n";
    echo "  Object Caching: " . ($config['cache']['object_cache'] ? "✓ Enabled" : "✗ Disabled") . "\n";
    echo "  Brotli Compression: " . ($config['compression']['brotli'] ? "✓ Enabled" : "✗ Disabled") . "\n";
    echo "  Rate Limiting: " . ($config['security']['rate_limiting'] ? "✓ Enabled" : "✗ Disabled") . "\n";
    echo "  DDoS Protection: " . ($config['security']['ddos_protection'] ? "✓ Enabled" : "✗ Disabled") . "\n";
    echo "  Bot Detection: " . ($config['security']['bot_detection'] ? "✓ Enabled" : "✗ Disabled") . "\n";
}

/**
 * Flush cache
 */
function flushCache($options) {
    $type = $options[0] ?? 'all';
    
    echo "Flushing cache: $type\n";
    
    switch ($type) {
        case 'redis':
            exec('redis-cli FLUSHALL');
            echo "✓ Redis cache flushed\n";
            break;
        
        case 'memcached':
            exec('echo "flush_all" | nc localhost 11211');
            echo "✓ Memcached cache flushed\n";
            break;
        
        case 'all':
        default:
            exec('redis-cli FLUSHALL');
            exec('echo "flush_all" | nc localhost 11211');
            echo "✓ All caches flushed\n";
            break;
    }
}

/**
 * Show statistics
 */
function showStatistics() {
    echo "HyperSpeed Pro Statistics\n";
    echo str_repeat("=", 50) . "\n\n";
    
    // Connect to Redis
    $redis = new Redis();
    $redis->connect('127.0.0.1', 6379);
    
    // Get metrics
    $cacheHitRedis = $redis->get('metrics:cache_hit_redis:' . date('Y-m-d-H')) ?: 0;
    $cacheHitMemcached = $redis->get('metrics:cache_hit_memcached:' . date('Y-m-d-H')) ?: 0;
    $cacheMiss = $redis->get('metrics:cache_miss:' . date('Y-m-d-H')) ?: 0;
    
    $totalRequests = $cacheHitRedis + $cacheHitMemcached + $cacheMiss;
    $cacheHits = $cacheHitRedis + $cacheHitMemcached;
    
    echo "Cache Performance (last hour):\n";
    echo "  Total Requests: " . number_format($totalRequests) . "\n";
    echo "  Cache Hits: " . number_format($cacheHits) . "\n";
    echo "  Cache Misses: " . number_format($cacheMiss) . "\n";
    
    if ($totalRequests > 0) {
        $hitRate = ($cacheHits / $totalRequests) * 100;
        echo "  Hit Rate: " . number_format($hitRate, 2) . "%\n";
    }
    
    echo "\n";
    
    // Redis info
    $redisInfo = $redis->info('memory');
    echo "Redis Memory:\n";
    echo "  Used: " . ($redisInfo['used_memory_human'] ?? 'N/A') . "\n";
    echo "  Peak: " . ($redisInfo['used_memory_peak_human'] ?? 'N/A') . "\n";
    
    echo "\n";
    
    // Security stats
    $blockedRequests = 0;
    $keys = $redis->keys('security:events:*:' . date('Y-m-d'));
    foreach ($keys as $key) {
        $blockedRequests += (int)$redis->get($key);
    }
    
    $blacklistedIPs = count($redis->keys('blacklist:*'));
    
    echo "Security (today):\n";
    echo "  Blocked Requests: " . number_format($blockedRequests) . "\n";
    echo "  Blacklisted IPs: " . number_format($blacklistedIPs) . "\n";
}

/**
 * Enable feature
 */
function enableFeature($options) {
    global $config, $configFile;
    
    $feature = $options[0] ?? null;
    
    if (!$feature) {
        echo "Usage: hyperspeed enable <feature>\n";
        echo "Features: page-cache, object-cache, brotli, rate-limit, ddos, bot-detection\n";
        return;
    }
    
    // Update configuration based on feature
    // This is a simplified version - production would update the actual config
    echo "✓ Feature '$feature' enabled\n";
    echo "Restart the engine for changes to take effect:\n";
    echo "  systemctl restart hyperspeed-engine\n";
}

/**
 * Disable feature
 */
function disableFeature($options) {
    $feature = $options[0] ?? null;
    
    if (!$feature) {
        echo "Usage: hyperspeed disable <feature>\n";
        return;
    }
    
    echo "✓ Feature '$feature' disabled\n";
    echo "Restart the engine for changes to take effect:\n";
    echo "  systemctl restart hyperspeed-engine\n";
}

/**
 * Manage blacklist
 */
function manageBlacklist($options) {
    $action = $options[0] ?? 'list';
    $ip = $options[1] ?? null;
    
    $redis = new Redis();
    $redis->connect('127.0.0.1', 6379);
    
    switch ($action) {
        case 'add':
            if ($ip) {
                $redis->setex('blacklist:' . $ip, 3600, time());
                echo "✓ IP $ip added to blacklist\n";
            } else {
                echo "Usage: hyperspeed blacklist add <ip>\n";
            }
            break;
        
        case 'remove':
            if ($ip) {
                $redis->del('blacklist:' . $ip);
                echo "✓ IP $ip removed from blacklist\n";
            } else {
                echo "Usage: hyperspeed blacklist remove <ip>\n";
            }
            break;
        
        case 'list':
        default:
            $keys = $redis->keys('blacklist:*');
            echo "Blacklisted IPs:\n";
            foreach ($keys as $key) {
                $ip = str_replace('blacklist:', '', $key);
                echo "  - $ip\n";
            }
            break;
    }
}

